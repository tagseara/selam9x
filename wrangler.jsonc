{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "selam9x",
  "compatibility_date": "2026-06-09",
  "observability": {
    "enabled": true
  },
  "main": ".output/server/index.mjs",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".output/public",
    "binding": "ASSETS"
  }
}
